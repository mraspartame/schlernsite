---
import Layout from '@layouts/Default.astro';
import { Card, Button } from '@eliancodes/brutal-ui';

const apps = [
  {
    slug: 'paint',
    name: 'A simple photo editor',
    description:
      'Not only for memes!',
    color: 'bg-pink',
    emoji: 'Scribble',
  },
  {
    slug: 'pdf',
    name: 'An intuitive free PDF editor',
    description:
      'Add text, shapes, highlights, signatures, and more. Watch out, DocuSign.',
    color: 'bg-orange',
    emoji: 'PDF Editor',
  },
  {
    slug: 'color',
    name: 'A free tool for basic color editing',
    description:
      'I\'m too cheap for Lightoom.',
    color: 'bg-purple',
    emoji: 'Color Editor',
  },
  {
    slug: 'converter',
    name: 'Reformat or compress images',
    description:
      'I don\'t trust those ad-ridden sites, so I did it myself.',
    color: 'bg-green',
    emoji: 'Image Converter',
  },
  {
    slug: 'audio',
    name: 'Test your mic or trim audio',
    description:
      'Audacity wasn\'t working on my computer :/',
    color: 'bg-yellow',
    emoji: 'Audio Tools',
  },
  {
    slug: 'expense',
    name: 'Expense Splitter',
    description:
      'Some may call this a rather wise way to split costs.',
    color: 'bg-pink',
    emoji: '💸',
  },
  {
    slug: 'transfer',
    name: 'Peer-to-Peer File Transfer',
    description:
      'Created as a good way to transfer files too large for emails or chats.',
    color: 'bg-blue',
    emoji: 'File Transfer',
  },
  {
    slug: 'qr',
    name: 'Open QR codes on your computer',
    description:
      'No longer frustrating to open a QR code on your desktop or laptop.',
    color: 'bg-purple',
    emoji: 'QR Relay',
  },
];
---

<Layout
  title='Apps'
  pageTitle='Schlern | Apps'
  description='Local apps running via your browser. No ads, log ins, or sending your data to Google.'
>
  <main class='bg-green p-6'>
    <section class='mb-8'>
      <Card>
        <h1 class='dm-serif text-4xl md:text-6xl mb-2'>Schlern Apps... Schlapps?</h1>
        <p class='poppins text-lg'>
          Local apps running via your browser. No ads, log ins, or sending your data to the Zuck.
        </p>
      </Card>
    </section>

    <div class='grid md:grid-cols-2 lg:grid-cols-3 gap-6'>
      {
        apps.map((app) => (
          <a href={`/apps/${app.slug}/`} class='block card-shadow'>
            <div class='border-4 border-black bg-white h-full flex flex-col'>
              <div class={`border-b-4 border-black p-6 ${app.color}`}>
                <span class='text-4xl'>{app.emoji}</span>
              </div>
              <div class='p-5 flex flex-col flex-1'>
                <h2 class='dm-serif text-2xl mb-2'>{app.name}</h2>
                <p class='poppins text-sm flex-1'>{app.description}</p>
                <p class='poppins text-sm font-bold mt-4'>Open app &rarr;</p>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
